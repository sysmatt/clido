; clido.ini.example — copy this to your deployment directory and edit
; This file lives next to the index.php symlink, not in the clido repo itself.

[global]

; Page title (shown in browser tab and sidebar header)
title         = CliDO

; Optional: URL to favicon and logo image
; favicon     = /favicon.ico
; logo        = /logo.png

; Default label for the execute button (can be overridden per item)
execute_text  = EXECUTE

; Path to simplewebauth/auth.php — absolute or relative to the document root.
; Omit to disable authentication (local/trusted-network deployments only).
simplewebauth = /var/www/html/simplewebauth/auth.php

; URL for the "sign out" link shown next to the logged-in username.
; Typically points to simplewebauth's logout.php.
logout_url    = /simplewebauth/logout.php

; Number of previous input sets to remember per item (stored in browser localStorage).
; Set to 0 to disable history entirely.
history_qty   = 5

; Show the full assembled command as the first line of output (true/false)
; Can be overridden per item. Default is false.
show_command  = false

; Maximum seconds a command may run before being killed (0 = unlimited)
max_runtime   = 0

; Seconds to wait between SIGTERM and SIGKILL when cancelling (0 = SIGKILL immediately)
sigkill_wait  = 5

; Dark-mode color palette — all values are CSS colors
; color_bg          = #0d1117
; color_sidebar     = #161b22
; color_accent      = #21262d
; color_border      = #30363d
; color_text        = #c9d1d9
; color_text_muted  = #8b949e
; color_btn         = #238636
; color_btn_text    = #ffffff
; color_cancel      = #da3633
; color_output_bg   = #010409
; color_output_text = #39d353


; ──────────────────────────────────────────────────────────────────────────────
; Groups provide section headers in the left menu.
; Items that follow a group appear under that group's header.
; ──────────────────────────────────────────────────────────────────────────────

[group: System]
title = System Tools

[item: disk_usage]
title         = Disk Usage
description   = Show disk usage for all mounted filesystems
command       = /bin/df
arg1          = -h

[item: uptime]
title         = Uptime
description   = System uptime and load averages
command       = /usr/bin/uptime

[item: process_list]
title         = Process List
description   = Show running processes
command       = /bin/ps
arg1          = aux


[group: Files]
title = File Tools

[item: list_dir]
title         = List Directory
description   = List the contents of a directory
command       = /bin/ls
arg1          = -lah
input2        = text
desc2         = Directory path
execute_text  = LIST

[item: find_files]
title         = Find Files
description   = Search for files matching a pattern
command       = /usr/bin/find
input1        = text
desc1         = Search path (e.g. /var/log)
arg2          = -name
input3        = text
desc3         = Filename pattern (e.g. *.log)
arg4          = -type
arg5          = f


[group: Network]
title = Network Tools

[item: ping_host]
title         = Ping Host
description   = Ping a hostname or IP address
command       = /bin/ping
arg1          = -c
arg2          = 5
input3        = text
desc3         = Hostname or IP
execute_text  = PING

[item: dns_lookup]
title         = DNS Lookup
description   = Resolve a hostname
command       = /usr/bin/dig
arg1          = +short
input2        = text
desc2         = Hostname to resolve
execute_text  = RESOLVE


[group: Reports]
title = Reports

[item: generate_report]
title         = Generate Report
description   = Generate and download the daily report archive
command       = /usr/local/bin/generate_report.sh
arg1          = --output-dir
arg2          = .
showfiles     = true
execute_text  = GENERATE
max_runtime   = 300


[group: Embedded Tools]
title = Embedded Tools

; URL items embed the target in the right pane instead of running a command.
; Omit command= entirely — just set url=.
; Note: the remote site must allow framing (no X-Frame-Options: DENY).
; Internal tools (Portainer, Grafana, Proxmox, pfSense, etc.) generally work fine.
; Most public internet sites will refuse to be embedded.

[item: portainer]
title         = Portainer
description   = Container management dashboard
url           = https://portainer.internal:9000

[item: grafana]
title         = Grafana
description   = Metrics and dashboards
url           = https://grafana.internal:3000


[group: Examples]
title = Input Type Examples

[item: checkbox_example]
title         = Checkbox Example
description   = Demonstrates checkbox input — toggle flag on/off
command       = /bin/echo
input1        = checkbox
desc1         = Enable verbose output
arg1_on       = --verbose
arg1_off      = --quiet
default1      = checked

[item: radio_example]
title         = Radio Button Example
description   = Demonstrates radio input — pick one option
command       = /bin/echo
arg1          = --format
input1        = radio
desc1         = Output format
opt1_1        = json
opt1_1_desc   = JSON (machine-readable)
opt1_2        = table
opt1_2_desc   = Table (human-readable)
opt1_3        = csv
opt1_3_desc   = CSV (spreadsheet)
default1      = table

[item: select_example]
title         = Select / Dropdown Example
description   = Demonstrates select input — same as radio but rendered as a dropdown
command       = /bin/echo
arg1          = --compress
input1        = select
desc1         = Compression algorithm
opt1_1        = gzip
opt1_1_desc   = Gzip
opt1_2        = bzip2
opt1_2_desc   = Bzip2
opt1_3        = none
opt1_3_desc   = No compression
default1      = gzip

[item: single_file_example]
title         = Single File Upload
description   = Upload one file and pass its path as an argument
command       = /usr/bin/wc
arg1          = -l
input2        = single_file
desc2         = File to count lines in
; → wc -l /tmp/clido_xxx/uploaded_files2/yourfile.txt

[item: file_list_example]
title         = File List Upload
description   = Upload multiple files; all paths passed after a single flag
command       = /usr/bin/sha256sum
input1        = file_list
desc1         = Files to checksum
; → sha256sum /tmp/clido_xxx/uploaded_files1/a.txt /tmp/clido_xxx/uploaded_files1/b.txt

[item: file_each_example]
title         = File Each Upload
description   = Upload multiple files; each is passed with its own flag prefix
command       = /usr/local/bin/process_files.sh
arg1          = --output-dir
arg2          = /tmp/results
arg3          = --input
input3        = file_each
desc3         = Input files
showfiles     = true
; → process_files.sh --output-dir /tmp/results --input 'a.txt' --input 'b.txt'
